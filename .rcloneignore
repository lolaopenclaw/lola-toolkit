# Rclone ignore file - excluye basura de backups
# Usado por: backup-memory.sh, manual rclone operations

# Directorios temporales
.cache/
.trash/
temp/
tmp/
/logs/

# Git (se regenera, ocupa mucho)
.git/
.gitignore
.gitattributes

# Node modules (se reinstalan con npm)
node_modules/
package-lock.json

# Bases de datos (se regeneran)
.vectordb/
*.db
*.sqlite
*.sqlite3

# Archivos de sistema operativo
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDEs
.vscode/
.idea/
*.iml

# Build artifacts
build/
dist/
*.o
*.a
*.so

# Archivos grandes innecesarios
*.iso
*.zip
*.rar
*.7z

# Logs y temporales
*.log
*.pid
*.tmp

# Node específico
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Videos/imágenes de test
test-videos/
test-images/
